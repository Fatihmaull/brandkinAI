# BrandKin AI - Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git

# Model Studio (Qwen AI)
MODELSTUDIO_API_KEY=your_modelstudio_api_key_here

# Alibaba Cloud Object Storage (OSS)
OSS_BUCKET=your_bucket_name_here
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here

# Database (MySQL / Alibaba Cloud RDS)
RDS_HOST=your_rds_hostname_here
RDS_PORT=3306
RDS_DATABASE=brandkin_db
RDS_USER=brandkin_user
RDS_PASSWORD=your_database_password_here

# CORS
CORS_ALLOWED_ORIGINS=*
