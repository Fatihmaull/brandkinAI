# ============================================================
# BrandKin AI - Environment Variables Template
# Copy this file and fill in values for your environment
# Backend: .env  |  Frontend: frontend/nextjs-app/.env.local
# ============================================================

# ---- Backend (FC Function Compute) ----

# Model Studio / DashScope International API Key (REQUIRED)
MODELSTUDIO_API_KEY=your-api-key-here

# Model Studio Base URL (optional — defaults to international endpoint)
# MODELSTUDIO_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model overrides (optional)
# MODEL_TEXT=qwen-max
# MODEL_CODE=qwen-max
# MODEL_IMAGE=wanx2.1-t2i-turbo

# OSS Configuration
OSS_BUCKET=brandkin-ai-assets
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# RDS MySQL Configuration
RDS_HOST=your-rds-host.mysql.rds.aliyuncs.com
RDS_PORT=3306
RDS_DATABASE=brandkin_ai
RDS_USER=brandkin_admin
RDS_PASSWORD=your-rds-password

# MNS Configuration
MNS_ENDPOINT=https://your-account-id.mns.cn-hangzhou.aliyuncs.com
MNS_QUEUE_NAME=brandkin-generation-tasks

# CORS (comma-separated origins, or * for all)
CORS_ALLOWED_ORIGINS=*

# ---- Frontend (Next.js) ----

# API Base URL
NEXT_PUBLIC_API_BASE_URL=https://your-api-gateway-id.cn-hangzhou.fcapp.run
